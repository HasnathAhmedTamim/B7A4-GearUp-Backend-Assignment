{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "strict": true,

    "outDir": "./dist",

    "types": ["node"],

    "sourceMap": true,

    "declaration": true,

    "declarationMap": true,

    "noUncheckedIndexedAccess": true,

    "exactOptionalPropertyTypes": true,

    "isolatedModules": true,

    "noUncheckedSideEffectImports": true,

    "moduleDetection": "force",

    "skipLibCheck": true
  }
}